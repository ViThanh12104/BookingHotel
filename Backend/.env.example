PORT=8080
NODE_ENV=development

# Database - Development
DB_DEV_USERNAME=root
DB_DEV_PASSWORD=your_password_here
DB_DEV_NAME=booking_hotel
DB_DEV_HOST=127.0.0.1
DB_DEV_PORT=3306

# Database - Test
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=your_password_here
DB_TEST_NAME=database_test
DB_TEST_HOST=127.0.0.1
DB_TEST_PORT=3306

# Database - Production
DB_PROD_USERNAME=root
DB_PROD_PASSWORD=your_secure_password_here
DB_PROD_NAME=database_production
DB_PROD_HOST=your_production_host
DB_PROD_PORT=3306

# JWT secret - change this in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (optional - for booking notifications)
EMAIL_USER=
EMAIL_PASS=
